# Application
DEBUG=False
LOG_LEVEL=INFO

# Redis (used for cache and rate limiting)
REDIS_URL=redis://redis:6379

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# CORS – comma-separated list or JSON array
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# CoinCap API (no key required)
COINCAP_BASE_URL=https://api.coincap.io/v2
COINCAP_TIMEOUT=10.0

# Cache TTLs (seconds)
CACHE_TTL_TOP=300
CACHE_TTL_DETAIL=60
CACHE_TTL_HISTORY=300
CACHE_TTL_SEARCH=120
